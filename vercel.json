{
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install && cd api && npm install && cd ../..",
  "outputDirectory": "client/dist",
  "functions": {
    "client/api/src/server.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/client/api/src/server.js?path=/$1"
    }
  ]
}
