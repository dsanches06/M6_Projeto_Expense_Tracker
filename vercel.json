{
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install && cd ../api && npm install",
  "outputDirectory": "client/dist",
  "env": {
    "VERCEL": "true"
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
