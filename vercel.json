{
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install",
  "outputDirectory": "client/dist",
  "functions": {
    "client/api/index.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/client/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
