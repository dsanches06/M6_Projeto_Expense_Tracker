{
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install && cd ../api && npm install",
  "outputDirectory": "client/dist",
  "env": {
    "VERCEL": "true"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
