{
  "buildCommand": "cd client && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install && cd client && npm install",
  "outputDirectory": "client/dist",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
