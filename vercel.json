{
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install && cd ../api && npm install",
  "outputDirectory": "client/dist",
  "env": {
    "VITE_API_URL": "/api",
    "VERCEL": "true",
    "DATABASE_URL": "@database_url"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/server.js"
    }
  ]
}
